    "mammoth": "^1.8.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.0.0",
    "nodemailer": "^6.9.0",
    "telegraf": "^4.16.0",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "dayjs": "^1.11.0"
